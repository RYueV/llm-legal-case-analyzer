      }
    },

    "source_coverage": {
      "type": "categorical",
      "description": "Обеспеченность признаков указанием источника.",
      "values": {
        "high": "почти все признаки имеют источник",
        "medium": "источник отсутствует для части признаков",
        "low": "значительная часть признаков не имеет источника"
      }
    },

    "consistency_status": {
      "type": "categorical",
      "description": "Общая логическая согласованность схемы.",
