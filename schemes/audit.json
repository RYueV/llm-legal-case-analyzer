          "values": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },

    "reextraction_targets": {
      "type": "text_array",
      "description": "Поля, которые необходимо попытаться доизвлечь."
    },

    "quality_score": {
      "type": "number",
      "description": "Интегральная оценка качества извлечения от 0 до 1."
    },

    "audit_result": {
      "type": "categorical",
      "description": "Итог проверки качества.",
      "values": {
        "accepted": "результат принят без доработки",
        "accepted_with_warnings": "результат принят с предупреждениями",
        "needs_reextraction": "необходимо доизвлечение",
        "manual_review_required": "требуется ручная проверка"
      }
