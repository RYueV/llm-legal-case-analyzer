        "consistent": "существенных противоречий не обнаружено",
        "minor_conflicts": "обнаружены незначительные противоречия",
        "major_conflicts": "обнаружены существенные противоречия"
      }
    },

    "confidence_status": {
      "type": "categorical",
      "description": "Общая надежность извлеченных признаков.",
      "values": {
        "high": "преобладают признаки с высокой уверенностью",
        "medium": "имеется заметное количество признаков со средней уверенностью",
        "low": "значительная часть признаков имеет низкую уверенность"
      }
    },

    "requires_reextraction": {
      "type": "binary",
      "description": "Требуется ли запуск механизма доизвлечения признаков."
    },

    "missing_blocks": {
      "type": "text_array",
      "description": "Список отсутствующих или недостаточно заполненных разделов."
    },

    "conflict_list": {
      "type": "array",
      "description": "Список выявленных противоречий.",
